{
  "name": "@3dagent/desktop",
  "version": "1.1.3",
  "private": true,
  "main": "src/main.cjs",
  "scripts": {
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win nsis",
    "build:api": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-api.ps1"
  },
  "devDependencies": {
    "electron": "35.7.5",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.3dagent.desktop",
    "productName": "3DAgent",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "!src/**/*.test.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web/.next/standalone",
        "to": "web",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../web/.next/standalone/node_modules",
        "to": "web/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../web/.next/static",
        "to": "web/apps/web/.next/static"
      },
      {
        "from": "../web/public",
        "to": "web/apps/web/public"
      },
      {
        "from": "../api/dist/3dagent-api.exe",
        "to": "api/3dagent-api.exe"
      },
      {
        "from": "../api/.env",
        "to": "api/.env",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../api/scripts",
        "to": "api/scripts"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://3dagent-updates-1411701740.cos.ap-guangzhou.myqcloud.com/3dagent/win/"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
