# Choose one: mock, meshy, hunyuan
MODEL_PROVIDER=hunyuan

# Tencent Cloud Hunyuan3D domestic API 3.0 auth.
# This requires Tencent Cloud SecretId + SecretKey, not a single sk-* key.
TENCENTCLOUD_SECRET_ID=your_tencentcloud_secret_id_here
TENCENTCLOUD_SECRET_KEY=your_tencentcloud_secret_key_here
TENCENTCLOUD_HUNYUAN_PROFILE=domestic
TENCENTCLOUD_REGION=ap-guangzhou

# Text-to-image provider.
IMAGE_PROVIDER=siliconflow
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_IMAGE_MODEL=Qwen/Qwen-Image

# Optional Meshy provider.
MESHY_API_KEY=your_meshy_api_key_here
