# Choose one: mock, meshy, hunyuan, neural4d
MODEL_PROVIDER=hunyuan

# Neural4D API auth and options.
NEURAL4D_API_TOKEN=your_neural4d_token_here
NEURAL4D_BASE_URL=https://alb.neural4d.com:3000/api
NEURAL4D_MODEL_COUNT=1

# Tencent Cloud Hunyuan3D domestic API 3.0 auth.
# This requires Tencent Cloud SecretId + SecretKey, not a single sk-* key.
TENCENTCLOUD_SECRET_ID=your_tencentcloud_secret_id_here
TENCENTCLOUD_SECRET_KEY=your_tencentcloud_secret_key_here
TENCENTCLOUD_HUNYUAN_PROFILE=domestic
TENCENTCLOUD_REGION=ap-guangzhou
TENCENTCLOUD_HUNYUAN_GENERATE_ACTION=SubmitHunyuanTo3DJob
TENCENTCLOUD_HUNYUAN_STATUS_ACTION=QueryHunyuanTo3DJob

# Text-to-image provider. Choose one: siliconflow, openai, mock
IMAGE_PROVIDER=siliconflow
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_IMAGE_MODEL=Kwai-Kolors/Kolors
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=low
OPENAI_IMAGE_MODERATION=auto

# Help chat provider.
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_CHAT_MODEL=mimo-v2.5-pro
CADAM_CHAT_MODEL=mimo-v2.5-pro
CADAM_LLM_PROVIDER=mimo
CADAM_OPENAI_BASE_URL=https://api.openai.com/v1
CADAM_OPENAI_MODEL=gpt-4o-mini

# Optional Meshy provider.
MESHY_API_KEY=your_meshy_api_key_here

# Supabase Auth.
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
